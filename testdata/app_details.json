","https://is1-ssl.mzstatic.com/image/thumb/PurpleSource221/v4/a8/d7/fa/a8d7fa64-a683-2976-f58a-d356d41acbd7/6.jpg/2048x2732bb.png"],"iwatch":[],"imessage_iphone":[],"imessage_ipad":[]},"trailers":{"iphone":{"img":"https://is1-ssl.mzstatic.com/image/thumb/PurpleVideo221/v4/a2/55/a4/a255a4ef-939b-88a6-96be-c260b64027d5/Jobe66314e9-b5dd-4459-afe9-601bcf47a2b3-212818390-PreviewImage_Preview_Image_Intermediate_nonvideo_416670215_2493385344-Time1767348777753.png/460x0w.jpeg","vid":"https://apptrailers.itunes.apple.com/itunes-assets/PurpleVideo211/v4/ad/5f/ed/ad5fed4c-e3e9-0382-7ef7-f4d44161d6fc/P1243902718_default.m3u8"},"ipad":{}},"active":true,"advertised_on_any_network":{"value":"Inactive (< last 28 Days)","name":"Advertised on Any Network","custom_fields_filter_id":{"errors":["Invalid params values: [\"Inactive (< last 28 Days)\"], name: \"Advertised on Any Network\""]}},"categories":[{"name":"Music","id":6011},{"name":"Utilities","id":6002}],"content_rating":"4+","description":{"full_description":"Playlist Transfer will help you to transfer your music from one platform to another. You can transfer your favorite albums, playlists, and songs to another music provider just in seconds with Playlist Transfer app. All you need to do is to connect your music services, choose the music you want to transfer and let Playlist Transfer app to discover compatible matches on the new music platform. Now you can enjoy your favorite music in your favorite platform<br><br>Playlist Transfer makes it super easy to transfer music to other platforms. Move your entire music library into a new music platform in seconds. Share music without limits! Works across all streaming apps. Share your playlist story on social media platform to let your friends discover new music and playlists. Playlist Transfer app supports many different music services such as Spotify, Apple Music, YouTube, Tidal and more are coming.<br><br>Frustrated with your streaming service? Download Playlist Transfer app now to transfer your favorite music across music platforms! Transfer your music from Spotify to Apple Music or Apple Music to Spotify. Don’t make your playlists again and again on every music service you use. Simply transfer your music with Playlist Transfer app.<br><br>How to Transfer Your Music with Playlist Transfer app?<br>1. Login with your current music platform such as Spotify, Apple Music etc.<br>2. Select the music platform that you want to transfer your music<br>3. Pick your favorite songs, albums, playlists that you want to transfer<br>4. Review and confirm the music transfer<br>5. Let Playlist Transfer app to transfer your music in seconds<br><br>Check your music stats with Playlist Transfer for Spotify Music Stats:<br>- Your top tracks, top artists and top albums<br>- How much you listen music on Spotify<br>- Music stats and song features (popularity, danceable, energetic…)<br>- Your lifetime Spotify streaming history for songs / artists / albums<br>- Personalized statistics for every song, artist, album on Spotify<br>- Find out popularity scores for every song, artist, album<br>- Discover new music with suggested songs<br><br>Supported Music Services<br>- Spotify<br>- Apple Music<br>- YouTube<br>- Soundcloud<br>- Deezer<br><br>Do you have any questions about Playlist Transfer app? We love receiving your feedback. You can reach us from:<br>hello@virals.app<br><br>You can find terms and privacy links of Playlist Transfer in here:<br>https://www.virals.app/terms<br>https://www.virals.app/privacy","app_summary":"'Playlist Transfer', published by a Turkey-based company and offers in-app purchases ranging from $5.99 to $39.99 per item. The app was last updated on 09 March 2026. Released in US on 13 March 2024 and globally on 13 March 2024. 'Playlist Transfer' belongs to the 'Music' category maintaining a content rating of '4+'. In US, 'Playlist Transfer' ranked 345th on the 'Top Free iPad Apps' chart, 176th on the 'Top Free iPhone Apps' chart, and 76th on the 'Top Grossing iPhone Apps' chart in the 'Music' category. Last month's estimates were 10k downloads and $60k revenue. The app is available in US, Mexico, and France but not being advertised actively. Sign up / Sign in to learn more about the time spent, session durations, usage & engagement (DAU, WAU, MAU), retention, churn, marketshare, growth trends, and other market statistics.","subtitle":"Spotify to Apple Music & Stats","promo_text":"Transfer PLAYLISTS and ALBUMS between SPOTIFY, APPLE MUSIC, YOUTUBE, SOUNDCLOUD and DEEZER. Transfer SONG & MUSIC between platforms with Playlist Transfer!"},"has_in_app_purchases":true,"installs":null,"language":"EN","support_url":"https://www.virals.app/","top_countries":["US","MX","FR"],"valid_countries":["AE","AO","AR","AT","AU","AZ","BE","BF","BG","BH","BJ","BO","BR","BY","CA","CG","CH","CI","CL","CM","CN","CO","CR","CY","CZ","DE","DK","DO","DZ","EC","EE","EG","ES","FI","FR","GB","GE","GH","GR","GT","HK","HR","HU","ID","IE","IL","IN","IQ","IT","JO","JP","KE","KH","KR","KW","KZ","LA","LB","LK","LT","LU","LV","LY","MA","ML","MM","MO","MT","MX","MY","MZ","NG","NI","NL","NO","NZ","OM","PA","PE","PH","PK","PL","PT","PY","QA","RO","RS","RU","SA","SE","SG","SI","SK","SN","SV","TH","TN","TR","TW","TZ","UA","UG","US","UY","UZ","VE","VN","YE","ZA","ZM","ZW"],"available_countries":["US","AU","CA","CN","FR","DE","GB","IT","JP","KR","RU","DZ","AO","AR","AT","AZ","BH","BB","BY","BE","BM","BR","BG","CL","CO","CR","HR","CY","CZ","DK","DO","EC","EG","SV","FI","GH","GR","GT","HK","HU","IN","ID","IE","IL","KZ","KE","KW","LB","LT","LU","MO","MG","MY","MT","MX","NL","NZ","NG","NO","OM","PK","PA","PE","PH","PL","PT","QA","RO","SA","RS","SG","SK","SI","ZA","ES","LK","SE","CH","TW","TH","TN","TR","UA","AE","UY","UZ","VE","VN","BO","KH","EE","LV","NI","PY","AF","GE","IQ","LY","MA","MZ","MM","YE","BJ","BF","CM","CG","CI","JO","LA","ML","SN","TZ","UG","ZM","ZW"],"pre_order_countries":[],"website_url":"https://www.virals.app/","app_id":6478631467,"app_view_